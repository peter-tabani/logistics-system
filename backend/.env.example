PORT=5000
DB_HOST=localhost
DB_PORT=5432
DB_NAME=logistics_db
DB_USER=postgres
DB_PASSWORD=your_postgres_password
JWT_SECRET=change_this_to_a_long_random_secret

# --- Pricing (customer bookings) ---
# Fare = FARE_BASE_KSH + km * FARE_PER_KM_KSH, rounded up to the nearest 10.
FARE_BASE_KSH=150
FARE_PER_KM_KSH=40

# --- M-Pesa / Safaricom Daraja (REAL-READY, NOT LIVE) ---
# Leave these empty to run in SIMULATE mode (no real money, DEMO flows).
# To go real: set MPESA_ENV=sandbox (then production after go-live approval)
# and fill in every value from your Daraja portal. Never commit real values.
MPESA_ENV=
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
# Public HTTPS base URL Safaricom can reach (your hosted backend URL).
MPESA_CALLBACK_BASE_URL=
